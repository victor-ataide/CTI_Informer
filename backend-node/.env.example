NODE_ENV=development
PORT=8101
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:thor@localhost:5432/cti?schema=cti_node
CORS_ORIGIN=*
CRON_COLLECT=*/10 * * * *
CRON_REFRESH=0 3 * * *
FEED_TIMEOUT_MS=10000
FEED_MAX_ENTRIES=50
SOURCES_FILE=../data/sources.json

# IOC enrichment (OTX + VirusTotal)
ENRICH_ENABLED=true
ENRICH_TIMEOUT_MS=6000
ENRICH_MAX_IOCS=6
OTX_API_KEY=
VIRUSTOTAL_API_KEY=
