# Arquivo de Variáveis de Ambiente para CTI System
# Copiar para .env e editar com seus dados

# ============================================================================
# OLLAMA (LLM Local)
# ============================================================================
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=60

# ============================================================================
# DISCORD
# ============================================================================
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
DISCORD_ENABLED=true

# ============================================================================
# CTI SYSTEM
# ============================================================================
CTI_LOG_LEVEL=INFO
CTI_INTERVAL_HOURS=1
CTI_RUN_ON_STARTUP=true

# ============================================================================
# OPTIONAL - Integrações Externas (Deixar vazio se não usar)
# ============================================================================

# SPLUNK HEC
SPLUNK_HEC_URL=https://splunk.empresa.com:8088
SPLUNK_HEC_TOKEN=

# MISP Integration
MISP_URL=https://misp.empresa.com
MISP_API_KEY=

# Twitter/X API (para collector_twitter.py)
TWITTER_API_KEY=
TWITTER_API_SECRET=

# Slack Webhook (alternativa ao Discord)
SLACK_WEBHOOK_URL=

# OTX API Key (Alien Vault - opcional)
OTX_API_KEY=

# VirusTotal API Key (opcional)
VIRUSTOTAL_API_KEY=

# NewsAPI Key (opcional para coleta via NewsAPI)
NEWSAPI_KEY=

# ============================================================================
# DEBUG (Deixar false em produção)
# ============================================================================
DEBUG=false
SAVE_INTERMEDIATE_DATA=false
VERBOSE_LOGGING=false

# ============================================================================
# COMO USAR ESTE ARQUIVO:
# ============================================================================
# 1. Copiar este arquivo: cp .env.example .env
# 2. Editar: nano .env
# 3. No código Python, usar:
#    from dotenv import load_dotenv
#    import os
#    load_dotenv()
#    webhook_url = os.getenv("DISCORD_WEBHOOK_URL")
# ============================================================================
