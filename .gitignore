docker-compose.override.yml

# ============================================================================
# 📊 ARQUIVOS TEMPORÁRIOS
# ============================================================================

# Temp files
tmp/
temp/
*.tmp
*.temp
*.swp

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Arquivos de teste/debug
test_output.json
debug_output.json
test.py
debug.py

# ============================================================================
# 🚀 DEPLOYMENT E PRODUÇÃO
# ============================================================================

# Arquivos de certificado/SSL
*.cert
*.crt
.ssl/

# Variáveis de produção
.env.production
.env.staging

# Arquivos de deployment
deploy/
*.tar
*.tar.gz
*.zip

# ============================================================================
# 🔄 GERENCIAMENTO DE VERSÃO
# ============================================================================

# Merge conflicts
*.orig
*.rej

# Git específico
.git/
.gitmodules

# ============================================================================
# 📄 ARQUIVOS DE COMPILAÇÃO E BUILD
# ============================================================================

*.o
*.a
*.dylib
*.dll
*.exe
*.out

# ============================================================================
# 🎯 ESPECÍFICOS DO CTI SYSTEM
# ============================================================================

# Arquivo de exemplo com dados reais (se não quer versionado)
data/exemplo_output.json        # Descomente se tiver dados sensíveis

# Diretório de backups
backups/

# Arquivos temporários do scheduler
.schedule_state

# PID files
*.pid

# Socket files
*.sock

# ============================================================================
# ✅ EXCEÇÕES - O que MANTER no repositório
# ============================================================================

# Manter templates de configuração
!.env.example
!config.json
!requirements.txt
!setup.sh

# Manter diretórios vazios com .gitkeep
!data/.gitkeep
!logs/.gitkeep
!data/results/.gitkeep

# Manter arquivos importantes
!README.md
!GUIA_RAPIDO.md
!TECNICO.md
!DISCORD_SETUP.md
!SYSTEMD_SETUP.md
!EXTENSOES.py
!START_HERE.txt
!CHECKLIST.txt

# ============================================================================
# 📋 NOTAS:
# ============================================================================

# 1. Sempre use .env.example como template, NUNCA versione .env real
# 2. Não faça commit de dados/results com informações reais de ameaças
# 3. Não versione logs (podem ter dados sensíveis)
# 4. Sempre use git credentials helper para evitar guardar passwords
# 5. Para secrets, use gerenciadores: AWS Secrets, HashiCorp Vault, etc
# 6. Configure git hooks para evitar commits acidentais:
#    git config core.hooksPath .git-hooks
